{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Sales OS",
  "version": "0.1.0",
  "identifier": "com.aisales.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175"
  },
  "app": {
    "windows": [
      {
        "title": "AI Sales OS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
