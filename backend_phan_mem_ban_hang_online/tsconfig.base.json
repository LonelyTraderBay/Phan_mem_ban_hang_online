{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ai-sales/auth-context": ["packages/auth-context/src/index.ts"],
      "@ai-sales/config": ["packages/config/src/index.ts"],
      "@ai-sales/contracts-events": ["packages/contracts-events/src/index.ts"],
      "@ai-sales/contracts-http": ["packages/contracts-http/src/index.ts"],
      "@ai-sales/database": ["packages/database/src/index.ts"],
      "@ai-sales/domain-kernel": ["packages/domain-kernel/src/index.ts"],
      "@ai-sales/idempotency": ["packages/idempotency/src/index.ts"],
      "@ai-sales/observability": ["packages/observability/src/index.ts"],
      "@ai-sales/outbox": ["packages/outbox/src/index.ts"],
      "@ai-sales/security": ["packages/security/src/index.ts"],
      "@ai-sales/test-utils": ["packages/test-utils/src/index.ts"],
      "@ai-sales/module-identity": ["modules/identity/src/index.ts"],
      "@ai-sales/module-tenant": ["modules/tenant/src/index.ts"],
      "@ai-sales/module-customer": ["modules/customer/src/index.ts"],
      "@ai-sales/module-catalog": ["modules/catalog/src/index.ts"],
      "@ai-sales/module-inventory": ["modules/inventory/src/index.ts"],
      "@ai-sales/module-knowledge": ["modules/knowledge/src/index.ts"],
      "@ai-sales/module-channel": ["modules/channel/src/index.ts"],
      "@ai-sales/module-conversation": ["modules/conversation/src/index.ts"],
      "@ai-sales/module-ai-orchestration": ["modules/ai-orchestration/src/index.ts"],
      "@ai-sales/module-order": ["modules/order/src/index.ts"],
      "@ai-sales/module-payment": ["modules/payment/src/index.ts"],
      "@ai-sales/module-fulfillment": ["modules/fulfillment/src/index.ts"],
      "@ai-sales/module-analytics": ["modules/analytics/src/index.ts"],
      "@ai-sales/module-billing": ["modules/billing/src/index.ts"],
      "@ai-sales/module-audit": ["modules/audit/src/index.ts"],
      "@ai-sales/module-operations": ["modules/operations/src/index.ts"]
    }
  }
}
