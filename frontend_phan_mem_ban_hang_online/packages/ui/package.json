{
  "name": "@ai-sales/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared design-system components (spec 7.2, FE-F00-003). May only import design-tokens and i18n (type-only) — never api-client/auth/app features (spec 4.3).",
  "type": "module",
  "sideEffects": false,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:storybook": "test-storybook",
    "build": "storybook build",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@ai-sales/design-tokens": "workspace:*",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-tooltip": "1.1.6",
    "@tanstack/react-table": "8.20.6",
    "@tanstack/react-virtual": "3.11.2",
    "clsx": "2.1.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ai-sales/eslint-config": "workspace:*",
    "@ai-sales/i18n": "workspace:*",
    "@ai-sales/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "8.4.7",
    "@storybook/react": "8.4.7",
    "@storybook/react-vite": "8.4.7",
    "@storybook/test-runner": "0.20.1",
    "@testing-library/react": "16.1.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "jsdom": "25.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "storybook": "8.4.7",
    "typescript": "6.0.3",
    "vite": "6.0.7",
    "vitest": "4.1.9"
  }
}
