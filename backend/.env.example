NODE_ENV=development
SERVICE_NAME=api
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://app_schema_owner:change-me-local-only@127.0.0.1:5432/ai_sales
REDIS_URL=redis://localhost:6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
WALKING_SKELETON_ENABLED=false

# OIDC BFF (BE-IDN-003) — local mock IdP: `node tools/mock-oidc-server.mjs` then set OIDC_ENABLED=true
OIDC_ENABLED=false
OIDC_ISSUER=http://127.0.0.1:9090
OIDC_CLIENT_ID=web-admin-local
OIDC_CLIENT_SECRET=local-dev-secret
OIDC_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback
OIDC_SCOPES=openid profile email
OIDC_AUTHORIZATION_ENDPOINT=http://127.0.0.1:9090/authorize
OIDC_TOKEN_ENDPOINT=http://127.0.0.1:9090/token
# Note: redirect_uri goes through Vite proxy (/api → /api/v1) so cookies stick to :5173
SESSION_COOKIE_NAME=ais_session
SESSION_COOKIE_SECURE=false
SESSION_ABSOLUTE_TTL_HOURS=12
REFRESH_TTL_DAYS=30

# Dev seed IDs (from `node tools/seed-dev-tenant.mjs`) — owner@dev.local
# SMOKE_TENANT_ID=01900000-0000-7000-8000-00000000a100
# SMOKE_ACTOR_ID=01900000-0000-7000-8000-00000000b100
# SMOKE_OWNER_ROLE_ID=01900000-0000-7000-8000-00000000d100

# Access JWT (BE-IDN-004) — ES256 for desktop/bearer clients (not Web Admin cookies)
JWT_ENABLED=false
# JWT_ISSUER=https://api.localhost
# JWT_AUDIENCE=aisales-api
# JWT_ACCESS_TTL_SECONDS=900
# JWT_ACTIVE_KID=2026-07
# JWT_ACTIVE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PREVIOUS_KID=2026-06
# JWT_PREVIOUS_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
