NODE_ENV=development
SERVICE_NAME=api
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgres://app_runtime:change-me@localhost:5432/ai_sales
REDIS_URL=redis://localhost:6379
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
AI_SERVICE_URL=http://localhost:8000
WALKING_SKELETON_ENABLED=false

# OIDC BFF (BE-IDN-003) — set OIDC_ENABLED=true and fill issuer/client when wiring an IdP
OIDC_ENABLED=false
# OIDC_ISSUER=https://idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oidc/callback
# OIDC_SCOPES=openid profile email
# OIDC_AUTHORIZATION_ENDPOINT=
# OIDC_TOKEN_ENDPOINT=
SESSION_COOKIE_NAME=ais_session
SESSION_COOKIE_SECURE=false
SESSION_ABSOLUTE_TTL_HOURS=12
REFRESH_TTL_DAYS=30

# Access JWT (BE-IDN-004) — ES256 for desktop/bearer clients (not Web Admin cookies)
JWT_ENABLED=false
# JWT_ISSUER=https://api.localhost
# JWT_AUDIENCE=aisales-api
# JWT_ACCESS_TTL_SECONDS=900
# JWT_ACTIVE_KID=2026-07
# JWT_ACTIVE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PREVIOUS_KID=2026-06
# JWT_PREVIOUS_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
