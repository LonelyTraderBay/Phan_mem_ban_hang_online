# Production env example — copy to `.env.production` (gitignored). Never commit secrets.

NODE_ENV=production
SERVICE_NAME=api
PORT=3000
LOG_LEVEL=info

# Supabase Free prod — ref sppdnlpbkdasmjealhjm · display Phan_mem_ban_hang_online-prod
# Reset DB password in Dashboard → Project Settings → Database, then:
DATABASE_URL=postgresql://postgres.sppdnlpbkdasmjealhjm:REPLACE_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

REDIS_URL=
OTEL_EXPORTER_OTLP_ENDPOINT=
WALKING_SKELETON_ENABLED=false

OIDC_ENABLED=true
OIDC_ISSUER=https://REPLACE_AUTH0_DOMAIN/
OIDC_CLIENT_ID=REPLACE_CLIENT_ID
OIDC_CLIENT_SECRET=REPLACE_CLIENT_SECRET
OIDC_REDIRECT_URI=https://phan-mem-ban-hang-online-web-prod.fly.dev/api/auth/oidc/callback
OIDC_SCOPES=openid profile email

SESSION_COOKIE_NAME=ais_session
SESSION_COOKIE_SECURE=true
SESSION_ABSOLUTE_TTL_HOURS=12
REFRESH_TTL_DAYS=30

# Generate new values — do not copy from .env.staging
# CSRF_SECRET=
# COOKIE_SIGNING_SECRET=
