{
  "name": "ai-sales-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise backend workspace for the AI Sales Operating System.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "check:node": "node tools/check-node-version.mjs",
    "agent:context": "node tools/agent-context.mjs",
    "agent:contract-slice": "node tools/extract-openapi-operation.mjs",
    "agent:gitnexus-reindex": "gitnexus analyze",
    "contracts:validate": "node tools/validate-contracts.mjs",
    "scaffold:module": "node tools/scaffold-module.mjs",
    "migrate": "node tools/migrate.mjs",
    "dev:api": "tsx apps/api/src/main.ts",
    "dev:worker": "tsx apps/worker/src/main.ts",
    "dev:scheduler": "tsx apps/scheduler/src/main.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:py": "uv run --project apps/ai-service --extra dev --python 3.13 pytest apps/ai-service/tests",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "verify": "corepack pnpm check:node && corepack pnpm contracts:validate && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test",
    "verify:all": "corepack pnpm verify && corepack pnpm test:py"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "pg": "8.22.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
