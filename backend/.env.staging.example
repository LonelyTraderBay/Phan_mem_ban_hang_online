# Staging — copy to `.env.staging` (gitignored). Never commit real secrets.
# Ticket: BE-FND-015 / BE-IDN-003. Fill after HO signs HO-STAGING-CHECKLIST.md

NODE_ENV=production
SERVICE_NAME=api
PORT=3000
LOG_LEVEL=info

# Managed Postgres (required) — secret store only
DATABASE_URL=postgres://REPLACE_USER:REPLACE_PASSWORD@REPLACE_HOST:5432/ai_sales

# Optional managed deps (BE-FND-015 HA baseline)
REDIS_URL=redis://REPLACE_REDIS_HOST:6379
OTEL_EXPORTER_OTLP_ENDPOINT=
AI_SERVICE_URL=
WALKING_SKELETON_ENABLED=false

# Object store (import/media) — wire when provider chosen
# OBJECT_STORE_BUCKET=
# OBJECT_STORE_REGION=
# OBJECT_STORE_ENDPOINT=

# OIDC BFF — real IdP only on staging (no mock :9090)
OIDC_ENABLED=true
OIDC_ISSUER=https://REPLACE_IDP/
OIDC_CLIENT_ID=REPLACE_CLIENT_ID
OIDC_CLIENT_SECRET=REPLACE_CLIENT_SECRET
OIDC_REDIRECT_URI=https://REPLACE_WEB_ADMIN_HOST/api/auth/oidc/callback
OIDC_SCOPES=openid profile email
# Leave blank to use issuer discovery, or set explicitly:
# OIDC_AUTHORIZATION_ENDPOINT=
# OIDC_TOKEN_ENDPOINT=

SESSION_COOKIE_NAME=ais_session
SESSION_COOKIE_SECURE=true
SESSION_ABSOLUTE_TTL_HOURS=12
REFRESH_TTL_DAYS=30

# Optional smoke IDs after staging seed
# SMOKE_TENANT_ID=
# SMOKE_ACTOR_ID=
# SMOKE_OWNER_ROLE_ID=

JWT_ENABLED=false

# Public URLs (for runbooks / FE) — not always read by API
# STAGING_API_BASE_URL=https://api.staging.example.com
# STAGING_WEB_ADMIN_URL=https://app.staging.example.com
# STAGING_SUPER_ADMIN_URL=https://ops.staging.example.com
